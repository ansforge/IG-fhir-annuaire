# Provides a complete explanation of the meaning of the data element for human readability.  For the case of elements derived from existing elements (e.g. constraints), the definition SHALL be consistent with the base definition, but convey the meaning of the element in the particular context of use of the resource. (Note: The text you are reading is specified in ElementDefinition.definition).
#: StructureDefinition.element.Extension/definition
msgid "Extension créée dans le cadre de l'Annuaire Santé pour décrire les certificats utilisés par les professionnels et les structures comme moyen d'identification."
msgstr "Extension créée dans le cadre de l'Annuaire Santé pour décrire les certificats utilisés par les professionnels et les structures comme moyen d'identification."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Extension.extension:serialNumber/short
msgid "numeroSerie : Numéro de série du certificat.
 format de codage des caractères en binaire codé en ASCII."
msgstr "numeroSerie : Numéro de série du certificat.
 format de codage des caractères en binaire codé en ASCII."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Extension.extension:issuer/short
msgid "dNEmetteur : DN (Distinguished Name 
 Nom distinctif) de l’autorité de certification (AC) émettrice du certificat.
 le format respecte le standard RFC-4514, avec un codage des caractères en UTF8"
msgstr "dNEmetteur : DN (Distinguished Name 
 Nom distinctif) de l’autorité de certification (AC) émettrice du certificat.
 le format respecte le standard RFC-4514, avec un codage des caractères en UTF8"

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Extension.extension:subject/short
msgid "dNSujet : DN (Distinguished Name - Nom distinctif) du porteur du certificat.
 codage des caractères en UTF8"
msgstr "dNSujet : DN (Distinguished Name - Nom distinctif) du porteur du certificat.
 codage des caractères en UTF8"

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Extension.extension:validity/short
msgid "Période de validité du certificat.
La date est en UTC (avec translation de l'heure locale en heure UTC par ajout du décalage négatif ou retranchement du décalage positif)."
msgstr "Période de validité du certificat.
La date est en UTC (avec translation de l'heure locale en heure UTC par ajout du décalage négatif ou retranchement du décalage positif)."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Extension.extension:validity.value[x].start/short
msgid "dateDebutValidite : Date et heure (en heure, minute, seconde) de début de validité du certificat."
msgstr "dateDebutValidite : Date et heure (en heure, minute, seconde) de début de validité du certificat."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Extension.extension:validity.value[x].end/short
msgid "dateFinValidite : Date et heure (en heure, minute, seconde) de fin de validité du certificat."
msgstr "dateFinValidite : Date et heure (en heure, minute, seconde) de fin de validité du certificat."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Extension.extension:domain/short
msgid "domaine : Ce champ correspond au CN du DNSujet, il contient soit un <FQDN> pour les certificats de type serveur <SSL>, soit un nom applicatif pour les autres certificats.
 renseigné uniquement pour les certificats logiciels de portée Structure."
msgstr "domaine : Ce champ correspond au CN du DNSujet, il contient soit un <FQDN> pour les certificats de type serveur <SSL>, soit un nom applicatif pour les autres certificats.
 renseigné uniquement pour les certificats logiciels de portée Structure."

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Extension.extension:keyUsage/short
msgid "usage : La clé d’usage (Keyusage) qui détermine l’usage autorisé du certificat.
 codage des caractères en binaire codé en ASCII"
msgstr "usage : La clé d’usage (Keyusage) qui détermine l’usage autorisé du certificat.
 codage des caractères en binaire codé en ASCII"

# A concise description of what this element means (e.g. for use in autogenerated summaries).
#: StructureDefinition.element.Extension.extension:value/short
msgid "valeurBinaire : Valeur binaire du certificat.
 format .crt en hexadécimal, codé en ASCII"
msgstr "valeurBinaire : Valeur binaire du certificat.
 format .crt en hexadécimal, codé en ASCII"

