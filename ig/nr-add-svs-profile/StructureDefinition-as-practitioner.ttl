       fhir:path [ fhir:v "Practitioner.identifier.value" ] ;
       fhir:short [ fhir:v "Identifiant national de la personne physique. 0 + ADELI ou 8 + RPPSidPP,\r\n Personne/Identifiant PP si l’instance correspond à un identifiant RPPS ou ADELI, sinon Personne/identification nationale PP." ] ;
