       ] [
         fhir:key [ fhir:v "per-1" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "If present, start SHALL have a lower value than end" ] ;
         fhir:expression [ fhir:v "start.hasValue().not() or end.hasValue().not() or (start <= end)" ] ;
         fhir:xpath [ fhir:v "not(exists(f:start/@value)) or not(exists(f:end/@value)) or (xs:dateTime(f:start/@value) <= xs:dateTime(f:end/@value))" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Identifier"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Identifier>
         ]
