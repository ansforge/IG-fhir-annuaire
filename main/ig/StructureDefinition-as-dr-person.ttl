       fhir:Element.id [ fhir:value "Person" ] ;
       fhir:ElementDefinition.path [ fhir:value "Person" ] ;
       fhir:ElementDefinition.short [ fhir:value "A generic person record" ] ;
       fhir:ElementDefinition.definition [ fhir:value "Demographics and administrative information about a person independent of a specific health-related context." ] ;
       fhir:ElementDefinition.comment [ fhir:value "The Person resource does justice to person registries that keep track of persons regardless of their role. The Person resource is also a primary resource to point to for people acting in a particular role such as SubjectofCare, Practitioner, and Agent. Very few attributes are specific to any role and so Person is kept lean. Most attributes are expected to be tied to the role the Person plays rather than the Person himself. Examples of that are Guardian (SubjectofCare), ContactParty (SubjectOfCare, Practitioner), and multipleBirthInd (SubjectofCare)." ] ;
       fhir:ElementDefinition.min [ fhir:value "0"^^xsd:nonNegativeInteger ] ;
       fhir:ElementDefinition.max [ fhir:value "*" ] ;
       fhir:ElementDefinition.base [
